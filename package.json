    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uri-templates": "^0.1.34",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.2.0",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^26.8.1",
